# Copia este archivo a .env y completa los valores. El .env esta ignorado por git.

# Modo seguro. true (default): nicole observa pero NO envia nada a WhatsApp.
# Poner false para habilitar el envio de mensajes.
READ_ONLY=true

# Carpeta de la sesion de WhatsApp.
AUTH_DIR=auth_state

# Capa de IA (proveedor intercambiable).
LLM_PROVIDER=opencode
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=deepseek-v4-flash

# Handoff del emit. Por defecto solo loguea la intencion (no la manda). Poner
# EMIT_ENABLED=true y un EMIT_WEBHOOK_URL para mandarla de verdad por HTTP POST
# a un webhook generico (no atado a n8n).
EMIT_ENABLED=false
EMIT_WEBHOOK_URL=
EMIT_TIMEOUT_MS=10000
EMIT_RETRIES=2

# Consola web: dashboard en vivo y editor de macros. Escucha solo en localhost.
WEB_ENABLED=true
WEB_HOST=127.0.0.1
WEB_PORT=4321

# Logs.
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
