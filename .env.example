# Copia este archivo a .env y completa los valores. El .env esta ignorado por git.

# Modo seguro. true (default): nicole observa pero NO envia nada a WhatsApp.
# Poner false para habilitar el envio de mensajes.
READ_ONLY=true

# Carpeta de la sesion de WhatsApp.
AUTH_DIR=auth_state

# Capa de IA (proveedor intercambiable).
LLM_PROVIDER=opencode
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=kimi-k2.7-code

# Logs.
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
